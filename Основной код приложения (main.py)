        self.filter_date_to.insert(0, today.strftime("%Y-%m-%d"))
    
    def validate_date(self, date_string):
        """Проверяет корректность даты"""
        pattern = r'^\d{4}-\d{2}-\d{2}$'
        if not re.match(pattern, date_string):
            return False
        try:
            datetime.strptime(date_string, "%Y-%m-%d")
            return True
        except ValueError:
            return False
    
    def add_expense(self):
        """Добавляет новый расход"""
        # Получение данных
        amount_str = self.amount_entry.get().strip()
        category = self.category_combo.get()
        date = self.date_entry.get().strip()
        description = self.description_entry.get().strip()
        
        # Валидация суммы
        if not amount_str:
            messagebox.showwarning("Ошибка", "Введите сумму расхода!")
            return
        
        try:
            amount = float(amount_str)
        except ValueError:
            messagebox.showwarning("Ошибка", f"'{amount_str}' — это не число!\nВведите числовое значение.")
            self.amount_entry.delete(0, tk.END)
            return
        
        if amount <= 0:
            messagebox.showwarning("Ошибка", "Сумма должна быть положительным числом!")
            self.amount_entry.delete(0, tk.END)
            return
        
        # Валидация даты
        if not self.validate_date(date):
            messagebox.showwarning("Ошибка", "Неверный формат даты!\nИспользуйте ГГГГ-ММ-ДД (например, 2024-01-15)")
            return
        
        # Добавление расхода
        expense = {
            "id": len(self.expenses) + 1,
            "date": date,
            "category": category,
            "amount": amount,
            "description": description
        }
        
        self.expenses.append(expense)
        self.save_expenses()
        self.update_table()
        self.update_statistics()
        
        # Очистка полей
        self.amount_entry.delete(0, tk.END)
        self.amount_entry.insert(0, "0.00")
        self.description_entry.delete(0, tk.END)
        
        self.status_label.config(text=f"✅ Расход добавлен: {amount:.2f} ₽ - {category}", fg="#4ecdc4")
        self.window.after(3000, lambda: self.status_label.config(text="💡 Готов к работе", fg="#888888"))
        
        # Сброс фильтра
        self.reset_filter()
    
    def delete_expense(self):
        """Удаляет выбранный расход"""
        selected = self.expense_tree.selection()
        if not selected:
            messagebox.showwarning("Ошибка", "Выберите расход для удаления!")
            return
        
        # Получаем ID расхода из таблицы
        item = selected[0]
        values = self.expense_tree.item(item, "values")
        expense_id = int(values[0])
        
        # Находим и удаляем расход
        for i, expense in enumerate(self.expenses):
            if expense["id"] == expense_id:
                if messagebox.askyesno("Подтверждение", f"Удалить расход:\n"
                                       f"📅 {expense['date']} | {expense['category']} | {expense['amount']:.2f} ₽"):
                    self.expenses.pop(i)
                    self.save_expenses()
                    self.update_table()
                    self.update_statistics()
                    self.filter_expenses()
                    self.status_label.config(text=f"🗑️ Расход удалён", fg="#ff6b6b")
                    self.window.after(3000, lambda: self.status_label.config(text="💡 Готов к работе", fg="#888888"))
                break
    
    def filter_expenses(self):
        """Фильтрует расходы по категории и дате"""
        category_filter = self.filter_category.get()
        date_from_str = self.filter_date_from.get().strip()
        date_to_str = self.filter_date_to.get().strip()
        
        filtered = self.expenses.copy()
        
        # Фильтр по категории
        if category_filter != "Все":
            filtered = [e for e in filtered if e["category"] == category_filter]
        
        # Фильтр по дате
        if date_from_str and self.validate_date(date_from_str):
            date_from = datetime.strptime(date_from_str, "%Y-%m-%d")
            filtered = [e for e in filtered if datetime.strptime(e["date"], "%Y-%m-%d") >= date_from]
        
        if date_to_str and self.validate_date(date_to_str):
            date_to = datetime.strptime(date_to_str, "%Y-%m-%d")
            filtered = [e for e in filtered if datetime.strptime(e["date"], "%Y-%m-%d") <= date_to]
        
        # Обновление таблицы
        self.update_table(filtered)
        
        # Подсчёт суммы за период
        period_total = sum(e["amount"] for e in filtered)
        self.period_total_label.config(text=f"Сумма за период: {period_total:,.2f} ₽")
        
        self.status_label.config(text=f"🔍 Найдено {len(filtered)} записей", fg="#f39c12")
        self.window.after(3000, lambda: self.status_label.config(text="💡 Готов к работе", fg="#888888"))
    
    def reset_filter(self):
        """Сбрасывает фильтр"""
        self.filter_category.set("Все")
        
        today = datetime.now()
        week_ago = today - timedelta(days=7)
        
        self.filter_date_from.delete(0, tk.END)
        self.filter_date_from.insert(0, week_ago.strftime("%Y-%m-%d"))
        
        self.filter_date_to.delete(0, tk.END)
        self.filter_date_to.insert(0, today.strftime("%Y-%m-%d"))
        
        self.update_table()
        self.update_statistics()
        
        period_total = sum(e["amount"] for e in self.expenses)
        self.period_total_label.config(text=f"Сумма за период: {period_total:,.2f} ₽")
        
        self.status_label.config(text="🔄 Фильтр сброшен", fg="#4ecdc4")
        self.window.after(3000, lambda: self.status_label.config(text="💡 Готов к работе", fg="#888888"))
    
    def update_table(self, expenses_list=None):
        """Обновляет таблицу расходов"""
        # Очищаем таблицу
        for item in self.expense_tree.get_children():
            self.expense_tree.delete(item)
        
        if expenses_list is None:
            expenses_list = self.expenses
        
        # Сортируем по дате (новые сверху)
        expenses_list.sort(key=lambda x: x["date"], reverse=True)
        
        # Добавляем записи
        for expense in expenses_list:
            self.expense_tree.insert("", "end", values=(
                expense["id"],
                expense["date"],
                expense["category"],
                f"{expense['amount']:,.2f}",
                expense["description"] if expense["description"] else "—"
            ))
    
    def update_statistics(self):
        """Обновляет статистику"""
        if not self.expenses:
            self.total_label.config(text="Общая сумма: 0.00 ₽")
            self.avg_label.config(text="Средний расход: 0.00 ₽")
            self.count_label.config(text="Всего записей: 0")
            return
        
        total = sum(e["amount"] for e in self.expenses)
        avg = total / len(self.expenses)
        
        self.total_label.config(text=f"Общая сумма: {total:,.2f} ₽")
        self.avg_label.config(text=f"Средний расход: {avg:,.2f} ₽")
        self.count_label.config(text=f"Всего записей: {len(self.expenses)}")
    
    def on_closing(self):
        """Обработка закрытия окна"""
        if self.save_expenses():
            self.window.destroy()
    
    def run(self):
        """Запуск приложения"""
        self.window.mainloop()

# Запуск программы
if __name__ == "__main__":
    app = ExpenseTracker()
    app.run()
