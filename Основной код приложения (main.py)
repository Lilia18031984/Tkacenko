import tkinter as tk
from tkinter import ttk, messagebox
import json
from datetime import datetime, timedelta
import re

class ExpenseTracker:
    """Приложение для отслеживания личных расходов"""
    
    def __init__(self):
        # Загрузка расходов из файла
        self.expenses = self.load_expenses()
        
        # Категории расходов
        self.categories = [
            "🍔 Еда", "🚗 Транспорт", "🎬 Развлечения", 
            "🏠 Жильё", "💊 Здоровье", "🛍️ Покупки", 
            "💼 Работа", "📚 Образование", "✈️ Путешествия",
            "📱 Связь", "⚡ Коммунальные", "🎁 Подарки",
            "🏦 Сбережения", "💰 Другое"
        ]
        
        # Создание главного окна
        self.window = tk.Tk()
        self.window.title("💰 Expense Tracker")
        self.window.geometry("1100x700")
        self.window.resizable(False, False)
        self.window.configure(bg="#1e1e2e")
        
        # Центрирование окна
        self.center_window()
        
        # Создание интерфейса
        self.create_widgets()
        
        # Загрузка данных в таблицу
        self.update_table()
        self.update_statistics()
        
        # Обработка закрытия окна
        self.window.protocol("WM_DELETE_WINDOW", self.on_closing)
    
    def center_window(self):
        """Центрирует окно на экране"""
        self.window.update_idletasks()
        width = 1100
        height = 700
        x = (self.window.winfo_screenwidth() // 2) - (width // 2)
        y = (self.window.winfo_screenheight() // 2) - (height // 2)
        self.window.geometry(f"{width}x{height}+{x}+{y}")
    
    def load_expenses(self):
        """Загружает расходы из JSON-файла"""
        try:
            with open("expenses.json", "r", encoding="utf-8") as file:
                expenses = json.load(file)
                if isinstance(expenses, list):
                    return expenses
                return []
        except FileNotFoundError:
            return []
        except json.JSONDecodeError:
            messagebox.showerror("Ошибка", "Файл expenses.json повреждён")
            return []
    
    def save_expenses(self):
        """Сохраняет расходы в JSON-файл"""
        try:
            with open("expenses.json", "w", encoding="utf-8") as file:
                json.dump(self.expenses, file, ensure_ascii=False, indent=4)
            return True
        except Exception as e:
            messagebox.showerror("Ошибка", f"Не удалось сохранить: {e}")
            return False
    
